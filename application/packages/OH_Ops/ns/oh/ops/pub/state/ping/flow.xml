<?xml version="1.0" encoding="UTF-8"?>

<FLOW VERSION="3.0" CLEANUP="true">
  <COMMENT></COMMENT>

  <!-- nodes -->

<INVOKE TIMEOUT="" SERVICE="oh.ops.pub.state:get" VALIDATE-IN="$none" VALIDATE-OUT="$none">
  <COMMENT></COMMENT>
</INVOKE>

<BRANCH TIMEOUT="" SWITCH="/state">
  <COMMENT></COMMENT>

  <!-- nodes -->

<MAP NAME="ACTIVE" TIMEOUT="" MODE="STANDALONE">
  <COMMENT></COMMENT>
</MAP>

<EXIT NAME="$default" FROM="$flow" SIGNAL="FAILURE" FAILURE-MESSAGE="Server in non-ACTIVE operational state. Current state: %state%.">
  <COMMENT></COMMENT>
</EXIT>
</BRANCH>
</FLOW>
