<?xml version="1.0" encoding="UTF-8"?>
<project name="ABE-Build" basedir="..">
    
    <!-- ABE Build Target -->
    <target name="abe.build" depends="abe.init, abe.prepare, abe.execute, abe.verify">
        <echo message="ABE build completed successfully"/>
    </target>
    
    <!-- Initialize ABE build -->
    <target name="abe.init">
        <echo message="=== Initializing ABE Build ==="/>
        <echo message="Project: ${bda.projectName}"/>
        <echo message="Build Number: ${bda.buildNumber}"/>
        <echo message="SAG Home: ${SAGHome}"/>
        <echo message="ABE Home: ${config.build.abeHome}"/>
        
        <!-- Verify ABE installation -->
        <available file="${config.build.abeHome}" type="dir" property="abe.exists"/>
        <fail unless="abe.exists" message="ABE not found at: ${config.build.abeHome}"/>
        
        <!-- Create build directories -->
        <mkdir dir="${config.tmpdir}"/>
        <mkdir dir="${config.build.buildStorageDir}"/>
        <mkdir dir="${fbrRepoDir}"/>
        
        <echo message="Build directories created"/>
    </target>
    
    <!-- Prepare ABE build properties -->
    <target name="abe.prepare">
        <echo message="=== Preparing ABE Build Properties ==="/>
        
        <!-- Create ABE build properties file -->
        <propertyfile file="${config.tmpdir}/abe-build.properties">
            <entry key="build.source.dir" value="${isPackagesDir}"/>
            <entry key="build.output.dir" value="${fbrRepoDir}"/>
            <entry key="repo.name" value="${fbrRepoName}"/>
            <entry key="project.name" value="${bda.projectName}"/>
            <entry key="build.number" value="${bda.buildNumber}"/>
        </propertyfile>
        
        <echo message="ABE properties file created: ${config.tmpdir}/abe-build.properties"/>
    </target>
    
    <!-- Execute ABE build -->
    <target name="abe.execute">
        <echo message="=== Executing ABE Build ==="/>
        <echo message="Building packages from: ${isPackagesDir}"/>
        <echo message="Target FBR directory: ${fbrRepoDir}"/>
        
        <!-- Define ABE's hardcoded output location based on OS -->
        <!-- Windows: Uses user.home from ANT -->
        <condition property="abe.hardcoded.output" value="${user.home}/Customer_Projects/Henry_Schen/implementation/build">
            <os family="windows"/>
        </condition>
        <!-- Unix/Linux: Uses user.home from ANT -->
        <condition property="abe.hardcoded.output" value="${user.home}/Customer_Projects/Henry_Schen/implementation/build">
            <os family="unix"/>
        </condition>
        
        <echo message="ABE hardcoded output location: ${abe.hardcoded.output}"/>
        
        <!-- Call ABE - it writes to hardcoded location regardless of -Dtarget parameter -->
        <exec executable="${config.build.abeHome}/bin/build.bat"
              dir="${config.build.abeHome}"
              failonerror="true"
              osfamily="windows">
            <arg value="-Dsource=${isPackagesDir}"/>
            <arg value="-Dtarget=${fbrRepoDir}"/>
            <arg value="-Dproject.name=${bda.projectName}"/>
        </exec>
        
        <exec executable="${config.build.abeHome}/bin/build.sh"
              dir="${config.build.abeHome}"
              failonerror="true"
              osfamily="unix">
            <arg value="-Dsource=${isPackagesDir}"/>
            <arg value="-Dtarget=${fbrRepoDir}"/>
            <arg value="-Dproject.name=${bda.projectName}"/>
        </exec>
        
        <echo message="ABE build execution completed"/>
        
        <!-- Verify ABE created output in hardcoded location -->
        <available file="${abe.hardcoded.output}/IS" type="dir" property="abe.hardcoded.exists"/>
        <fail unless="abe.hardcoded.exists" message="ABE did not create output at hardcoded location: ${abe.hardcoded.output}/IS"/>
        
        <!-- Copy all ABE output from hardcoded location to FBR directory -->
        <echo message="Copying ABE artifacts from ${abe.hardcoded.output} to ${fbrRepoDir}"/>
        <copy todir="${fbrRepoDir}" overwrite="true" verbose="true">
            <fileset dir="${abe.hardcoded.output}">
                <!-- Copy entire IS directory structure (includes ACDL, ZIP, and _assets.obj) -->
                <include name="IS/**/*"/>
                <!-- Copy root-level index files -->
                <include name="_index"/>
                <include name="_compositeIndex"/>
                <include name="_assets.obj"/>
            </fileset>
        </copy>
        
        <!-- Verify final FBR directory has required files -->
        <available file="${fbrRepoDir}/IS" type="dir" property="abe.is.exists"/>
        <available file="${fbrRepoDir}/_index" type="file" property="abe.index.exists"/>
        
        <fail unless="abe.is.exists" message="Missing IS directory in: ${fbrRepoDir}"/>
        
        <!-- Warn if _index is missing but don't fail - Deployer might still work -->
        <condition property="index.missing">
            <not><isset property="abe.index.exists"/></not>
        </condition>
        <antcall target="abe.warn.missing.index"/>
        
        <echo message="ABE artifacts successfully assembled in: ${fbrRepoDir}"/>
        <echo message="Contents:"/>
        <exec executable="cmd" osfamily="windows" failonerror="false">
            <arg value="/c"/>
            <arg value="dir"/>
            <arg value="/s"/>
            <arg value="${fbrRepoDir}"/>
        </exec>
        <exec executable="ls" osfamily="unix" failonerror="false">
            <arg value="-laR"/>
            <arg value="${fbrRepoDir}"/>
        </exec>
    </target>
    
    <!-- Warning target for missing index file -->
    <target name="abe.warn.missing.index" if="index.missing">
        <echo message="WARNING: _index file not found in ${fbrRepoDir}. Deployment may fail."/>
    </target>
    
    <!-- Verify build output -->
    <target name="abe.verify">
        <echo message="=== Verifying Build Output ==="/>
        
        <!-- Check if FBR directory exists and has content -->
        <available file="${fbrRepoDir}" type="dir" property="fbr.exists"/>
        <fail unless="fbr.exists" message="Build failed: FBR directory not created at ${fbrRepoDir}"/>
        
        <!-- List build artifacts -->
        <echo message="Build artifacts in ${fbrRepoDir}:"/>
        <exec executable="cmd" osfamily="windows">
            <arg value="/c"/>
            <arg value="dir"/>
            <arg value="${fbrRepoDir}"/>
        </exec>
        
        <exec executable="ls" osfamily="unix">
            <arg value="-la"/>
            <arg value="${fbrRepoDir}"/>
        </exec>
        
        <echo message="Build verification completed"/>
    </target>
    
    <!-- Clean ABE build artifacts -->
    <target name="abe.clean">
        <echo message="=== Cleaning ABE Build Artifacts ==="/>
        <delete dir="${fbrRepoDir}" failonerror="false"/>
        <delete file="${config.tmpdir}/abe-build.properties" failonerror="false"/>
        <echo message="ABE artifacts cleaned"/>
    </target>
    
</project>

